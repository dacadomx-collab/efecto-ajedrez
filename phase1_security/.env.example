; =============================================================================
; AXON_DCD — AXON_DCD v1.0.0
; Archivo   : .env.example
; Entorno   : produccion
; Generado  : 2026-06-11 07:51:26 — FoundationExecutor v1.0 — AXON_GENESIS
; PLANTILLA PÚBLICA — Reemplazar todos los valores **marcados** antes de usar
; Leer con  : parse_ini_file(__DIR__ . '/.env.example', false, INI_SCANNER_RAW)
; =============================================================================

; ── Base de Datos Remota ─────────────────────────────────────────────────────
DB_HOST = your-db-host.websitehostserver.net
DB_NAME = your_database_name
DB_USER = your_db_username
DB_PASS = **your-db-password**

; ── FTP / Despliegue ─────────────────────────────────────────────────────────
FTP_HOST       = ftp.yourdomain.com
FTP_USER       = your-ftp-username
FTP_PASSWORD   = **your-ftp-password**
FTP_SERVER_DIR = /public_html/

; ── SMTP Transaccional ───────────────────────────────────────────────────────
SMTP_HOST     = smtp.yourmailprovider.com
SMTP_USER     = no-reply@yourdomain.com
SMTP_PASSWORD = **your-smtp-password**
SMTP_PORT     = "465"
SMTP_FROM     = no-reply@yourdomain.com
SMTP_SECURE   = ssl

; ── Aplicación ───────────────────────────────────────────────────────────────
APP_ENV         = produccion
APP_NAME        = AXON_DCD
ALLOWED_ORIGINS = https://yourdomain.com

; ── Next.js Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL = https://yourdomain.com/api

; ── Claves Criptográficas (Mandamiento 12 — Bóveda de Secretos) ─────────────
; Generar: php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
AI_ENCRYPTION_KEY  = CHANGE_ME_64_HEX_CHARS_AI_ENCRYPTION_KEY
GENESIS_VAULT_KEY  = CHANGE_ME_64_HEX_CHARS_GENESIS_VAULT_KEY
