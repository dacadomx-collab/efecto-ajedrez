# =============================================================================
# PROYECTO  : El Efecto Ajedrez — Mentores al Revés
# ARCHIVO   : .htaccess (Raíz)
# VERSIÓN   : 2.0 — Parche de compatibilidad cPanel / Tourfindy (2026-06-29)
# PROPÓSITO : Apertura limpia sobre directorio padre cPanel +
#             Blindaje perimetral silencioso de carpetas internas.
# =============================================================================

# ── PASO 1: APERTURA DE ACCESO (anula restricción heredada del padre cPanel) ─
Order allow,deny
Allow from all
Satisfy Any
Require all granted

DirectoryIndex index.php index.html

# ── PASO 2: BLINDAJE PERIMETRAL SILENCIOSO (carpetas internas) ───────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloqueo perimetral de carpetas internas — 403 si intentan entrar por HTTP
    RewriteRule (^|/)knowledge(/|$)          - [F,L,NC]
    RewriteRule (^|/)database(/|$)           - [F,L,NC]
    RewriteRule (^|/)logs(/|$)               - [F,L,NC]
    RewriteRule (^|/)backups(/|$)            - [F,L,NC]
    RewriteRule (^|/)artifacts(/|$)          - [F,L,NC]
    RewriteRule (^|/)\.git(/|$)              - [F,L,NC]
    RewriteRule (^|/)\.github(/|$)           - [F,L,NC]

    # Rutas físicas (assets/, api/, TPN/) pasan directamente sin reescritura
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# ── PASO 3: BLOQUEO DE ARCHIVOS CRÍTICOS SUELTOS ─────────────────────────────
# Doble capa: legacy (Order/Deny) + moderno (Require) para compatibilidad con
# el contexto Satisfy Any del Paso 1. Ambas deben denegar para blindaje total.
<FilesMatch "(?i)\.(env|sql|log|ini|yml|yaml)$">
    Order allow,deny
    Deny from all
    Require all denied
</FilesMatch>
