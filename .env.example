; =============================================================================
; PROYECTO  : El Efecto Ajedrez — Mentores al Revés
; ARCHIVO   : .env.example  (Plantilla Pública — sí se sube a Git)
; USO       : Copiar este archivo como .env en local y servidor. NUNCA subir .env real a GitHub.
; =============================================================================

; ── ENTORNO ──────────────────────────────────────────────────────────────────
APP_ENV = "local"            ; Valores: local | staging | production
APP_URL = "http://localhost/El_Efecto_ajedrez_PODCAST"
APP_DEBUG = "true"           ; Cambiar a false en producción

; ── BASE DE DATOS ─────────────────────────────────────────────────────────────
; REGLA CERO (Aislamiento de Entornos): la BD NUNCA es local, ni en desarrollo.
; El frontend/backend corre en localhost, pero DB_HOST SIEMPRE apunta al
; servidor remoto centralizado. Jamás usar "localhost" o "127.0.0.1" aquí.
DB_HOST = "chir205.websitehostserver.net"
DB_NAME = "tourfindycom_ajedrez_db"
DB_USER = "tourfindycom_ajedrez_user_db"
DB_PASS = "contrasena_bd"

; ── SEGURIDAD Y AUTENTICACIÓN ─────────────────────────────────────────────────
; JWT_SECRET: Mínimo 64 caracteres aleatorios. Generar con: openssl rand -base64 64
; o con scripts/generate_jwt_keys.php
JWT_SECRET       = "REEMPLAZAR_CON_STRING_LARGO_Y_ALEATORIO_MINIMO_64_CHARS"
JWT_ACCESS_TTL   = "900"     ; Access token: 15 minutos
JWT_REFRESH_TTL  = "2592000" ; Refresh token: 30 días
JWT_TTL          = "3600"    ; Legado — TTL genérico para jwtEncode()/jwtDecode() sin tipar

; Orígenes permitidos (CORS) — separados por coma, sin espacios
ALLOWED_ORIGINS = "https://tudominio.com,http://localhost"
FRONTEND_URL    = "https://tudominio.com"

; ── API KEYS Y SERVICIOS EXTERNOS ─────────────────────────────────────────────
; Pasarela de pagos (descomenta la que uses)
PAYPAL_CLIENT_ID     = "tu_client_id_aqui"
PAYPAL_SECRET        = "tu_secret_aqui"
PAYPAL_MODE          = "sandbox"    ; sandbox | live
; STRIPE_SECRET_KEY  = "sk_test_aqui"
; STRIPE_PUBLIC_KEY  = "pk_test_aqui"

; IA / OpenAI
; OPENAI_API_KEY     = "sk-..."
; OPENAI_MODEL       = "gpt-4o-mini"

; ── CORREO (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST     = "efecto-ajedrez.tourfindy.com"
SMTP_PORT     = "465"
SMTP_SECURE   = "ssl"        ; tls | ssl
SMTP_USER     = "hola@efecto-ajedrez.tourfindy.com"
SMTP_PASS     = "tu_password_smtp"
MAIL_FROM_NAME = "El Efecto Ajedrez"

; ── ALMACENAMIENTO (S3 / Compatible) ──────────────────────────────────────────
; AWS_ACCESS_KEY_ID     = "tu_access_key"
; AWS_SECRET_ACCESS_KEY = "tu_secret_key"
; AWS_BUCKET            = "nombre-del-bucket"
; AWS_REGION            = "us-east-1"

; ── CI/CD (SOLO usar como GitHub Secrets — no escribir valores reales aquí) ───
; FTP_SERVER     = "ftp.tudominio.com"
; FTP_USERNAME   = "usuario_ftp"
; FTP_PASSWORD   = "password_ftp"
; FTP_REMOTE_DIR = "/public_html/"
